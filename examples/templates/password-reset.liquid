{% layout "base" %}
{% block content %}

<h1>{{ i18n.heading }}</h1>

<p style="padding-bottom: 30px">{{ i18n.body }}</p>

<a
  class="button"
  rel="noopener"
  target="_blank"
  href="{{ url }}"
  style="
    font-size: 16px;
    font-weight: 600;
    color: #ffffff;
    text-decoration: none;
    display: inline-block;
    padding: 11px 24px;
    border-radius: 8px;
    background: #171717;
    border: 1px solid #ffffff;
  "
>
  <!--[if mso]>
    <i style="letter-spacing: 25px; mso-font-width: -100%; mso-text-raise: 30pt">&nbsp;</i>
  <![endif]-->
  <span style="mso-text-raise: 15pt">{{ i18n.cta }}</span>
  <!--[if mso]>
    <i style="letter-spacing: 25px; mso-font-width: -100%">&nbsp;</i>
  <![endif]-->
</a>

<p style="padding-top: 30px">{{ i18n.expiry_notice }}</p>

{% endblock %}
